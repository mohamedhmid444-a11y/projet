  <property name="windowTitle">
   <string>Smart Scene Switcher - Dashboard</string>
  </property>
  <property name="styleSheet">
   <string notr="true">QWidget#MainDashboard {
  background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #0b0f18, stop:1 #131a2b);
  color: #e6f1ff;
  font-family: "Rajdhani";
}
QFrame#topBar,
QFrame#bottomBar {
  background-color: #0f1826;
  border: 1px solid #27324a;
  border-radius: 12px;
}
QFrame#heroFrame {
  background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #101a2b, stop:1 #12243d);
  border: 1px solid #27324a;
  border-radius: 14px;
}
QLabel#labelAppTitle {
  font-size: 20px;
  font-weight: 700;
}
QLabel#labelAppSubtitle,
QLabel#labelHeroSubtitle {
  color: #8fa3c5;
}
QLabel#labelHeroTitle {
  font-size: 18px;
  font-weight: 600;
}
QLabel#labelSectionTitle {
  color: #8fa3c5;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 1px;
}
QLabel#labelHeroChipMode,
QLabel#labelHeroChipLatency,
QLabel#labelHeroChipProfile {
  background-color: #0b2238;
  color: #4ef0ff;
  border: 1px solid #2a8cff;
  border-radius: 10px;
  padding: 4px 10px;
}
QFrame#statusDot {
  background-color: #ef476f;
  border-radius: 6px;
}
QFrame#cardAudio,
QFrame#cardFace,
QFrame#cardActiveWindow,
QFrame#cardGameStatus,
QFrame#cardGeneral {
  background-color: #121a28;
  border: 1px solid #25344b;
  border-radius: 14px;
}
QFrame#cardAudio:hover,
QFrame#cardFace:hover,
QFrame#cardActiveWindow:hover,
QFrame#cardGameStatus:hover,
QFrame#cardGeneral:hover {
  border: 1px solid #4ef0ff;
  background-color: #16223a;
}
QLabel#labelAudioDesc,
QLabel#labelFaceDesc,
QLabel#labelActiveWindowDesc,
QLabel#labelGameStatusDesc,
QLabel#labelGeneralDesc {
  color: #9bb0d0;
}
QPushButton {
  background-color: #2a8cff;
  color: #ffffff;
  border-radius: 8px;
  padding: 6px 14px;
  font-weight: 600;
}
QPushButton:hover {
  background-color: #47a1ff;
}
QPushButton#btnLogout {
  background-color: #223043;
}
QPushButton#btnLogout:hover {
  background-color: #2a3a54;
}
QPushButton#btnStartPlugin {
  background-color: #00f5d4;
  color: #06211d;
}
QPushButton#btnStartPlugin:hover {
  background-color: #36ffe4;
}
QPushButton#btnStopPlugin {
  background-color: #ef476f;
}
QPushButton#btnStopPlugin:hover {
  background-color: #ff6b86;
}</string>
