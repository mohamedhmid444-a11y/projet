  <property name="styleSheet">
   <string notr="true">QWidget#LoginWindow {
  background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #0f1116, stop:1 #1b2333);
  color: #e6e6e6;
}
QLabel#labelTitle {
  font-size: 22px;
  font-weight: 600;
}
QLabel#labelSubtitle {
  color: #9aa0a6;
}
QLineEdit {
  background-color: #1c1f26;
  border: 1px solid #2b2f3a;
  border-radius: 8px;
  padding: 8px;
  color: #f5f5f5;
}
QLineEdit:focus {
  border: 1px solid #5aa2ff;
}
QCheckBox {
  color: #cbd5e1;
}
QPushButton {
  background-color: #3a86ff;
  color: #ffffff;
  border-radius: 8px;
  padding: 8px 16px;
}
QPushButton:hover {
  background-color: #5aa2ff;
}
QPushButton#btnShowSignup,
QPushButton#btnShowLogin {
  background: transparent;
  color: #9cc4ff;
  text-decoration: underline;
  padding: 4px;
}
QPushButton#btnShowSignup:hover,
QPushButton#btnShowLogin:hover {
  color: #cfe2ff;
}</string>
