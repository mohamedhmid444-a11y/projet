    <property name="styleSheet">
     <string notr="true">QWidget#GameStatusTab {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #0b0f18, stop:1 #142038);
    color: #e6f1ff;
}
QFrame#headerFrame {
    background-color: #0f1826;
    border: 1px solid #27324a;
    border-radius: 14px;
}
QLabel#labelHeaderTitle {
    font-size: 22px;
    font-weight: 600;
}
QLabel#labelHeaderSubtitle {
    color: #8fa3c5;
}
QLabel#labelHeaderStatus {
    background-color: #0b2238;
    color: #4ef0ff;
    padding: 6px 12px;
    border-radius: 12px;
    border: 1px solid #2a8cff;
}
QGroupBox {
    background-color: #121a26;
    border: 1px solid #23304a;
    border-radius: 12px;
    margin-top: 10px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 6px;
    color: #a9b8d4;
    font-weight: 600;
}
QListWidget, QComboBox, QSpinBox, QTableWidget {
    background-color: #0e1522;
    border: 1px solid #26334b;
    border-radius: 8px;
    padding: 6px;
}
QListWidget::item:selected,
QTableWidget::item:selected {
    background-color: #2a8cff;
    color: #0b0f16;
}
QHeaderView::section {
    background-color: #111b2b;
    color: #8fa3c5;
    border: none;
    padding: 6px;
}
QComboBox::drop-down {
    border: none;
}
QScrollArea {
  background: transparent;
}
QScrollArea > QWidget > QWidget {
  background: transparent;
}
QCheckBox {
    color: #c7d2e3;
}
QPushButton {
    background-color: #2a8cff;
    color: #ffffff;
    border-radius: 8px;
    padding: 6px 14px;
}
QPushButton:hover {
    background-color: #47a1ff;
}
QPushButton#btnReset {
    background-color: #223043;
}
QPushButton#btnReset:hover {
    background-color: #2a3a54;
}
QPushButton#btnApply {
    background-color: #00f5d4;
    color: #06211d;
}
QPushButton#btnApply:hover {
    background-color: #36ffe4;
}
QLabel#labelRunStateBadge {
    background-color: #13213a;
    border: 1px solid #2a8cff;
    border-radius: 10px;
    padding: 4px 10px;
    font-weight: 600;
}
QLabel#labelScanHint,
QLabel#labelHeaderSubtitle {
    color: #8fa3c5;
}</string>
